# ─── WooCommerce Headless API ────────────────────────────────
# The Store API (wc/store/v1) requires NO authentication for
# read operations (products, categories, cart).
#
# Point this to your WordPress + WooCommerce instance.
# Local dev: http://localhost:8080  (Docker)
# Production: https://your-wp-domain.com
NEXT_PUBLIC_WOOCOMMERCE_URL=http://localhost:8080
