    },
    {
      "name": "Shop Rings",
      "short_name": "Rings",
      "description": "Discover our stunning ring collection",
      "url": "/category/rings",
      "icons": [
        {
          "src": "/icons/shortcut-rings.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "View Cart",
      "short_name": "Cart",
      "description": "View your shopping cart",
